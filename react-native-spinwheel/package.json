{
  "name": "react-native-spinwheel",
  "version": "1.0.0",
  "description": "React Native wrapper for SpinWheel Android Home Screen Widget",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "android",
    "!android/build",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "build": "bob build",
    "prepare": "bob build",
    "typescript": "tsc --noEmit",
    "pack": "npm pack"
  },
  "keywords": [
    "react-native",
    "android",
    "widget",
    "spinwheel",
    "home-screen-widget"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/codebaron/react-native-spinwheel"
  },
  "author": "CodeBaron",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/codebaron/react-native-spinwheel/issues"
  },
  "homepage": "https://github.com/codebaron/react-native-spinwheel#readme",
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "react-native-builder-bob": "^0.23.0",
    "typescript": "^5.0.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
